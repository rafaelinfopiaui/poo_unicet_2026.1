# --- JAVA & JVM ---
# Ignora binários compilados (.class) e pacotes
*.class
*.jar
*.war
*.ear
# Pasta de build padrão de algumas IDEs
bin/

# --- ANTIGRAVITY / VS CODE ---
# Ignora configurações específicas da IDE e histórico local
.vscode/
*.code-workspace
.history/
.antigravity/

# --- AMBIENTE WSL / OS ---
# Arquivos de sistema do Windows e Linux no subsistema
.DS_Store
Thumbs.db
desktop.ini
$RECYCLE.BIN/
.fuse_hidden*

# --- LOGS E TEMPORÁRIOS ---
*.log
*.tmp
.cache/
npm-debug.log*
yarn-debug.log*
yarn-error.log*

# --- ESPECÍFICO DE PROJETOS ---
# Se usar algum arquivo de configuração de banco ou segredos no futuro
.env
